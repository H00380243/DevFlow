# DemandFlow 环境变量模板

# LLM API 配置
# 大模型 API 密钥（OpenAI/兼容格式）
# Required by features: F008, F009, F010, F012, F013, F015
LLM_API_KEY=

# LLM 模型名称
LLM_MODEL_NAME=gpt-4

# LLM API 基础地址（兼容 OpenAI 格式）
# 例如：https://api.openai.com/v1 或 https://your-proxy.com/v1
LLM_BASE_URL=https://api.openai.com/v1

# Git 仓库配置
# Git 仓库地址（HTTPS 或 SSH）
# Required by features: F018
GIT_REPO_URL=

# Git 分支前缀
GIT_BRANCH_PREFIX=feature/

# IM 平台配置
# IM 平台类型（dingtalk/feishu/slack）
# Required by features: F003
IM_PLATFORM=dingtalk

# IM Webhook 签名密钥
# Required by features: F003
IM_WEBHOOK_SECRET=

# MinIO 存储配置
# MinIO 服务地址
# Required by features: F013, F019
MINIO_ENDPOINT=localhost:9000

# MinIO 访问密钥
# Required by features: F013, F019
MINIO_ACCESS_KEY=

# MinIO 密钥
# Required by features: F013, F019
MINIO_SECRET_KEY=

# SQLite 数据库路径
DATABASE_URL=sqlite:///data/demandflow.db

# Huey 任务队列路径
HUEY_URL=sqlite:///data/huey_queue.db

# 调试模式
DEBUG=false
